[Unit]
Description=SFO Kalshi paper exit monitor
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=__APP_USER__
WorkingDirectory=__TRADING_DIR__
EnvironmentFile=__ENV_FILE__
ExecStart=__TRADING_DIR__/.venv/bin/python -m sfo_kalshi_quant.cli --no-color --forecaster-root __FORECASTER_DIR__ --db-path __TRADING_DIR__/data/paper_trading.db paper-monitor --take-profit-pct ${PAPER_TAKE_PROFIT_PCT} --stop-loss-pct ${PAPER_STOP_LOSS_PCT}
Nice=5
